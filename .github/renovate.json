{
	"extends": ["github>noelforte/renovate-config"],
	"semanticCommits": "disabled",
	"vulnerabilityAlerts": {
		"labels": ["security"],
		"automerge": true,
		"vulnerabilityFixStrategy": "highest"
	},
	"assignees": ["noelforte"],
	"packageRules": [
		{
			"matchDepNames": ["ventojs", "debug"],
			"automergeType": "pr",
			"automerge": false
		}
	]
}
