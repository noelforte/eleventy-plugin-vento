{
	"name": "eleventy-plugin-vento",
	"version": "5.4.3",
	"description": "Adds support for the Vento templating language to Eleventy.",
	"type": "module",
	"engines": {
		"node": ">=18"
	},
	"types": "./dist/plugin.d.mts",
	"exports": {
		".": {
			"import": "./dist/plugin.mjs",
			"types": "./dist/plugin.d.mts"
		}
	},
	"files": [
		"dist/*",
		"LICENSE",
		"CHANGELOG.md",
		"readme.md"
	],
	"repository": "git@github.com:noelforte/eleventy-plugin-vento.git",
	"bugs": {
		"url": "https://github.com/noelforte/eleventy-plugin-vento/issues"
	},
	"keywords": [
		"eleventy",
		"eleventy-plugin",
		"ventojs",
		"templating"
	],
	"author": {
		"name": "Noel Forte",
		"email": "noel@forte.is",
		"url": "https://forte.is/"
	},
	"license": "MIT",
	"dependencies": {
		"debug": "4.4.3",
		"ventojs": "2.3.1"
	},
	"devDependencies": {
		"@11ty/eleventy": "3.1.6",
		"@changesets/cli": "2.31.0",
		"@eslint/js": "10.0.1",
		"@types/debug": "4.1.13",
		"@types/node": "24.13.2",
		"eslint": "10.5.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-unicorn": "68.0.0",
		"globals": "17.7.0",
		"knip": "6.17.1",
		"prettier": "3.8.4",
		"tsdown": "0.22.3",
		"typescript": "6.0.3",
		"typescript-eslint": "8.62.0",
		"vitest": "4.1.9"
	}
}
